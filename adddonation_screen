  //  IMAGE METHODS
  Future<void> _pickImages() async {
    try {
      final List<XFile> images = await _picker.pickMultiImage(
        maxWidth: 1024,
        maxHeight: 1024,
        imageQuality: 70,
      );

      if (images.isNotEmpty && mounted) {
        setState(() {
          _selectedImages.addAll(images); // Store XFile directly
        });
      }
    } catch (e) {
      debugPrint('Error picking images: $e');
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          const SnackBar(
            content: Text('Failed to pick images'),
            backgroundColor: Colors.red,
          ),
        );
      }
    }
  }

  void _removeImage(int index) {
    setState(() {
      _selectedImages.removeAt(index);
    });
  }

  Future<List<String>> _uploadImages(String donationId) async {
    List<String> imageUrls = [];
    debugPrint('🚀 Starting image upload for donation: $donationId');
    debugPrint('📸 Total images to upload: ${_selectedImages.length}');

    // Get current user ID for the path
    final authProvider = Provider.of<AuthProvider>(context, listen: false);
    final donorId = authProvider.user?.uid ?? 'unknown';

    for (int i = 0; i < _selectedImages.length; i++) {
      final XFile image = _selectedImages[i];
      //  Include donorId in the path to match storage rules
      final fileName = 'donation_images/$donorId/${donationId}_image_$i.jpg';

      try {
        debugPrint('📤 Uploading image $i...');
        debugPrint('📁 Path: $fileName');

        final ref = FirebaseStorage.instance.ref().child(fileName);

        if (kIsWeb) {
          // WEB: Upload as bytes
          debugPrint('🌐 Web platform: Uploading as bytes');
          final Uint8List imageBytes = await image.readAsBytes();
          await ref.putData(
            imageBytes,
            SettableMetadata(contentType: 'image/jpeg'),
          );
        } else {
          // MOBILE: Upload as file
          debugPrint('📱 Mobile platform: Uploading as file');
          final File file = File(image.path);
          await ref.putFile(file);
        }

        final url = await ref.getDownloadURL();
        debugPrint('✅ Image $i uploaded, URL: $url');
        imageUrls.add(url);
      } catch (e) {
        debugPrint('❌ Error uploading image $i: $e');
        if (e is FirebaseException) {
          debugPrint('❌ Firebase error code: ${e.code}');
          debugPrint('❌ Firebase error message: ${e.message}');
        }
      }
    }

    debugPrint('✅ Upload complete. Total URLs: ${imageUrls.length}');
    return imageUrls;
  }

  //  SUBMIT FORM
  Future<void> _submitForm() async {
    if (_formKey.currentState!.validate()) {
      // Show loading
      if (!mounted) return;

      showDialog(
        context: context,
        barrierDismissible: false,
        builder: (_) => const Center(
          child: CircularProgressIndicator(color: Colors.orange),
        ),
      );

      try {
        // Get current user
        final authProvider = Provider.of<AuthProvider>(context, listen: false);
        final user = authProvider.user;

        if (user == null) {
          if (mounted) {
            Navigator.pop(context); // Close loading
            ScaffoldMessenger.of(context).showSnackBar(
              const SnackBar(
                content: Text('Please login first'),
                backgroundColor: Colors.red,
              ),
            );
          }
          return;
        }

        // Debug info
        debugPrint('=== DEBUG INFO ===');
        debugPrint('User ID: ${user.uid}');
        debugPrint('User Role: ${authProvider.userData?['role']}');
        debugPrint('Is Donor: ${authProvider.userData?['role'] == 'Donor'}');
        debugPrint('Donation data:');
        debugPrint('- Title: ${_titleController.text}');
        debugPrint('- Description: ${_descriptionController.text}');
        debugPrint('- Quantity: ${_quantityController.text}');
        debugPrint('- Category: $_selectedCategory');
        debugPrint('- Location: ${_locationController.text}');
        debugPrint('=================');

        // Check if user has Donor role
        if (authProvider.userData?['role'] != 'Donor') {
          if (mounted) {
            Navigator.pop(context); // Close loading
            _showRoleUpdateDialog();
          }
          return;
        }

        // Create donation object
        final tempDonation = DonationModel(
          id: '',
          donorId: user.uid,
          donorName:
              authProvider.userData?['name'] ?? user.displayName ?? 'User',
          isAnonymous: _isAnonymous,
          category: _selectedCategory!,
          title: _titleController.text,
          description: _descriptionController.text,
          quantity: int.tryParse(_quantityController.text) ?? 1,
          condition: _selectedCondition!,
          brand:
              _brandController.text.isNotEmpty ? _brandController.text : null,
          size: _sizeController.text.isNotEmpty ? _sizeController.text : null,
          color:
              _colorController.text.isNotEmpty ? _colorController.text : null,
          gender: _selectedGender,
          material: _materialController.text.isNotEmpty
              ? _materialController.text
              : null,
          urgency: _selectedUrgency!,
          location: _locationController.text,
          contact: _contactController.text,
          canPickup: _canPickup,
          canDeliver: _canDeliver,
          donorImageUrls: [],
          proofImageUrl: null,
          recipientInfo: null,
          completedAt: null,
          status: DonationStatus.pending,
          rejectionReason: null,
          createdAt: DateTime.now(),
          isAvailable: true,
        );

        // Save to Firebase
        final donationProvider =
            Provider.of<DonationProvider>(context, listen: false);

        final docId = await donationProvider.submitDonation(tempDonation);

        if (docId == null) {
          if (mounted) {
            Navigator.pop(context); // Close loading
            ScaffoldMessenger.of(context).showSnackBar(
              const SnackBar(
                content: Text(
                    'Failed to submit donation. Please check your network and try again.'),
                backgroundColor: Colors.red,
              ),
            );
          }
          return;
        }

        debugPrint('✅ Donation created with ID: $docId');

        // Upload images if any
        List<String> uploadedImageUrls = [];
        if (_selectedImages.isNotEmpty) {
          setState(() => _isUploading = true);
          uploadedImageUrls = await _uploadImages(docId);
          debugPrint('📸 Uploaded ${uploadedImageUrls.length} images');
          debugPrint('📸 Image URLs: $uploadedImageUrls');

          // Update donation with image URLs immediately
          if (uploadedImageUrls.isNotEmpty) {
            await donationProvider.updateDonationImages(
                docId, uploadedImageUrls);
            debugPrint('✅ Updated donation with image URLs');
          }
        }

        if (mounted) {
          Navigator.pop(context); // Close loading dialog

          // Show success message
          ScaffoldMessenger.of(context).showSnackBar(
            const SnackBar(
              content: Text(
                  'Donation submitted for review! The team will contact you soon.'),
              backgroundColor: Colors.green,
              duration: Duration(seconds: 4),
            ),
          );

          // Go back to donor home
          Navigator.pop(context);
        }
      } catch (e) {
        debugPrint('❌ Error in donation submission: $e');
        if (mounted) {
          Navigator.pop(context); // Close loading dialog

          ScaffoldMessenger.of(context).showSnackBar(
            SnackBar(
              content: Text('Error: ${e.toString()}'),
              backgroundColor: Colors.red,
            ),
          );
        }
      }
    }
  }

  // Show dialog to update user role
  void _showRoleUpdateDialog() {
    showDialog(
      context: context,
      builder: (ctx) => AlertDialog(
        title: const Text('Role Required'),
        content:
            const Text('You need to have the "Donor" role to submit donations. '
                'Would you like to update your role now?'),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(ctx),
            child: const Text('Cancel'),
          ),
          ElevatedButton(
            onPressed: () async {
              Navigator.pop(ctx); // Close dialog

              // Show loading
              if (!mounted) return;

              showDialog(
                context: context,
                barrierDismissible: false,
                builder: (_) => const Center(
                  child: CircularProgressIndicator(color: Colors.orange),
                ),
              );

              try {
                final authProvider =
                    Provider.of<AuthProvider>(context, listen: false);
                final user = authProvider.user;

                if (user != null) {
                  // Update user role in Firestore
                  await FirebaseFirestore.instance
                      .collection('users')
                      .doc(user.uid)
                      .update({
                    'role': 'Donor',
                  });

                  // Refresh user data
                  await authProvider.fetchUserData();

                  if (mounted) {
                    Navigator.pop(context); // Close loading

                    ScaffoldMessenger.of(context).showSnackBar(
                      const SnackBar(
                        content: Text(
                            'Role updated to Donor! You can now submit donations.'),
                        backgroundColor: Colors.green,
                      ),
                    );
                  }
                }
              } catch (e) {
                debugPrint('Error updating role: $e');
                if (mounted) {
                  Navigator.pop(context); // Close loading
                  ScaffoldMessenger.of(context).showSnackBar(
                    SnackBar(
                      content: Text('Error updating role: $e'),
                      backgroundColor: Colors.red,
                    ),
                  );
                }
              }
            },
            style: ElevatedButton.styleFrom(
              backgroundColor: Colors.orange,
            ),
            child: const Text('Update Role'),
          ),
        ],
      ),
    );
  }

