}

// Data classes
class _FeatureData {
  final String title;
  final IconData icon;
  final Color iconColor, iconBg, accent;

  const _FeatureData(
      this.title, this.icon, this.iconColor, this.iconBg, this.accent);
}

class _ImpactData {
  final String title, desc;
  final IconData icon;
  final Color iconColor, iconBg;

  const _ImpactData(
      this.title, this.desc, this.icon, this.iconColor, this.iconBg);
}
