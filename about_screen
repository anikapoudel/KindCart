                    ),
                    const SizedBox(width: 8),
                    Text('Making consumption kinder',
                        style: TextStyle(
                            fontSize: 11.5,
                            color: Colors.white.withOpacity(0.88))),
                  ]),
                ),
              ],
            ),
          ),
        ),
      ]),
    );
  }

  // Layout helpers
  Widget _section(
      {required String label, required String title, required Widget child}) {
    return Padding(
      padding: const EdgeInsets.fromLTRB(20, 26, 20, 0),
      child: Column(crossAxisAlignment: CrossAxisAlignment.start, children: [
        _label(label),
        _title(title),
        const SizedBox(height: 10),
        child,
      ]),
    );
  }

  Widget _label(String t) => Padding(
        padding: const EdgeInsets.only(bottom: 4),
        child: Text(t.toUpperCase(),
            style: const TextStyle(
              fontSize: 10,
              fontWeight: FontWeight.w600,
              letterSpacing: 2,
              color: _brightGreen,
            )),
      );

  Widget _title(String t) => Text(t,
      style: const TextStyle(
        fontSize: 21,
        fontWeight: FontWeight.w700,
        color: _deepGreen,
        fontFamily: 'serif',
      ));

  Widget _divider() => Container(
        margin: const EdgeInsets.symmetric(horizontal: 20, vertical: 22),
        height: 1,
        decoration: const BoxDecoration(
          gradient: LinearGradient(
              colors: [Colors.transparent, _sand, Colors.transparent]),
        ),
      );

  // Feature single row
  Widget _featureRow() {
    final items = [
      _FeatureData(
          'Thrift Shopping',
          Icons.shopping_bag_outlined,
          const Color(0xFF2D6A4F),
          const Color(0xFFF0FAF2),
          const Color(0xFF40916C)),
      _FeatureData(
          'Easy Donations',
          Icons.favorite_outline,
          const Color(0xFF2563EB),
          const Color(0xFFEFF6FF),
          const Color(0xFF3B82F6)),
      _FeatureData('Reduce Waste', Icons.autorenew, const Color(0xFFD97706),
          const Color(0xFFFFFBEB), const Color(0xFFF59E0B)),
      _FeatureData('Community', Icons.people_outline, const Color(0xFF7C3AED),
          const Color(0xFFF5F3FF), const Color(0xFF8B5CF6)),
    ];

    return Padding(
      padding: const EdgeInsets.symmetric(horizontal: 20),
      child: Row(
        children: List.generate(
            items.length,
            (i) => Expanded(
                  child: Padding(
                    padding:
                        EdgeInsets.only(right: i < items.length - 1 ? 8 : 0),
                    child: _featureCard(items[i]),
                  ),
                )),
      ),
    );
  }

  Widget _featureCard(_FeatureData d) {
    return Container(
      decoration: BoxDecoration(
        color: Colors.white,
        borderRadius: BorderRadius.circular(12),
        border: Border.all(color: _sand),
      ),
      clipBehavior: Clip.hardEdge,
      child: Column(children: [
        Container(height: 3, color: d.accent),
        Padding(
          padding: const EdgeInsets.symmetric(vertical: 12, horizontal: 6),
          child: Column(children: [
            Container(
              width: 32,
              height: 32,
              decoration: BoxDecoration(
                color: d.iconBg,
                borderRadius: BorderRadius.circular(9),
              ),
              child: Icon(d.icon, color: d.iconColor, size: 16),
            ),
            const SizedBox(height: 7),
            Text(
              d.title,
              textAlign: TextAlign.center,
              style: const TextStyle(
                  fontSize: 10.5, fontWeight: FontWeight.w600, height: 1.3),
            ),
          ]),
        ),
      ]),
    );
  }

  // Impact list
  Widget _impactList() {
    final items = [
      _ImpactData(
          'Circular Economy',
          'Every item re-homed means one less manufactured — and one less ending up in a landfill.',
          Icons.autorenew,
          const Color(0xFF2D6A4F),
          const Color(0xFFF0FAF2)),
      _ImpactData(
          'Community First',
          'Donations reach local families directly — no middlemen, no delays.',
          Icons.home_outlined,
          const Color(0xFF0D9488),
          const Color(0xFFF0FDFA)),
      _ImpactData(
          'Conscious Living',
          'Buy less new, give more, and feel genuinely good about every choice.',
          Icons.shield_outlined,
          const Color(0xFF4F46E5),
          const Color(0xFFEEF2FF)),
    ];
    return Padding(
      padding: const EdgeInsets.symmetric(horizontal: 20),
      child: Column(
        children: items
            .map((d) => Padding(
                  padding: const EdgeInsets.only(bottom: 10),
                  child: _impactCard(d),
                ))
            .toList(),
      ),
    );
  }

  Widget _impactCard(_ImpactData d) {
    return Container(
      decoration: BoxDecoration(
        color: Colors.white,
        borderRadius: BorderRadius.circular(16),
        border: Border.all(color: _sand),
