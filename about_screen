import 'package:flutter/material.dart';
import 'package:url_launcher/url_launcher.dart';
import 'auth_screen.dart';

class AboutScreen extends StatelessWidget {
  final bool isLoggedIn;

  const AboutScreen({super.key, this.isLoggedIn = false});

  static const _deepGreen = Color(0xFF1A3A2A);
  static const _midGreen = Color(0xFF2D6A4F);
  static const _brightGreen = Color(0xFF40916C);
  static const _lightGreen = Color(0xFF74C69D);
  static const _cream = Color(0xFFFAF7F2);
  static const _sand = Color(0xFFE8E0D5);
  static const _textMid = Color(0xFF4A4A4A);
  static const _textMuted = Color(0xFF8A8A8A);

  Future<void> _launchEmail(String email) async {
    final uri = Uri(scheme: 'mailto', path: email);
    if (!await launchUrl(uri)) throw 'Could not open email app';
  }

  Future<void> _launchPhone(String phone) async {
    final uri = Uri(scheme: 'tel', path: phone);
    if (!await launchUrl(uri)) throw 'Could not open phone dialer';
  }

  Future<void> _launchMaps(String address) async {
    final uri = Uri(
      scheme: 'https',
      host: 'www.google.com',
      path: '/maps/search/',
      queryParameters: {'query': address},
    );
    if (!await launchUrl(uri)) throw 'Could not open maps';
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: _cream,
      body: CustomScrollView(
        slivers: [
          SliverAppBar(
            expandedHeight: 248,
            pinned: true,
            backgroundColor: _deepGreen,
            leading: IconButton(
              icon: Container(
                padding: const EdgeInsets.only(bottom: 2),
                decoration: BoxDecoration(
                  color: Colors.white.withOpacity(0.15),
                  shape: BoxShape.circle,
                ),
                child:
                    const Icon(Icons.arrow_back, size: 18, color: Colors.white),
              ),
              onPressed: () => Navigator.pop(context),
            ),
            title: const Text(
              'About KindCart',
              style: TextStyle(
                  color: Colors.white,
                  fontSize: 16,
                  fontWeight: FontWeight.w500),
            ),
            centerTitle: false,
            titleSpacing: 0,
            flexibleSpace: FlexibleSpaceBar(background: _buildHero()),
          ),
          SliverToBoxAdapter(
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                _section(
                  label: 'Who we are',
                  title: 'Our Mission',
                  child: const Text(
                    'KindCart enables buying and selling second-hand items while making donations effortless. '
                    'We\'re building a community rooted in sustainable consumption, ethical fashion, '
                    'and genuine care for others — because doing good shouldn\'t be complicated.',
                    style:
                        TextStyle(fontSize: 14, color: _textMid, height: 1.75),
                  ),
                ),
                _divider(),
                Padding(
                  padding: const EdgeInsets.fromLTRB(20, 0, 20, 14),
                  child: Column(
                      crossAxisAlignment: CrossAxisAlignment.start,
                      children: [
                        _label('What we offer'),
                        _title('What We Do'),
                      ]),
                ),
                _featureRow(),
                _divider(),
                Padding(
                  padding: const EdgeInsets.fromLTRB(20, 0, 20, 14),
                  child: Column(
                      crossAxisAlignment: CrossAxisAlignment.start,
                      children: [
                        _label('Why it matters'),
                        _title('Our Impact'),
