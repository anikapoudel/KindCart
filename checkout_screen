  }

  // Main order processing function
  Future<void> _processOrder() async {
    debugPrint('🚀 Starting order processing');
    setState(() => _isLoading = true);

    final cart = Provider.of<CartProvider>(context, listen: false);
    final authProvider =
        Provider.of<app_auth.AuthProvider>(context, listen: false);
    final orderProvider = Provider.of<OrderProvider>(context, listen: false);
    final chatProvider = Provider.of<ChatProvider>(context, listen: false);

    debugPrint('📊 Cart items count: ${cart.items.length}');
    debugPrint('👤 User ID: ${authProvider.user?.uid}');
    debugPrint('💳 Payment method: $_selectedPaymentMethod');

    try {
      if (cart.items.isEmpty) {
        debugPrint('❌ Cart is empty');
        _showError('Your cart is empty');
        setState(() => _isLoading = false);
        return;
      }

      // Group items by seller
      final Map<String, List<Map<String, dynamic>>> sellerItems = {};
      final Map<String, String> sellerNames = {};
      final Map<String, String> sellerPhones = {};

      for (var item in cart.items) {
        final sellerId = item['sellerId'] ?? 'unknown';
        final sellerName = item['sellerName'] ?? 'Unknown Seller';
        final sellerPhone = item['sellerPhone'] ?? 'Not provided';

        debugPrint('📦 Item seller: $sellerName ($sellerId)');

        if (!sellerItems.containsKey(sellerId)) {
          sellerItems[sellerId] = [];
          sellerNames[sellerId] = sellerName;
          sellerPhones[sellerId] = sellerPhone;
        }
        sellerItems[sellerId]!.add(item);
      }

      debugPrint('👥 Found ${sellerItems.length} unique sellers');

      // Track successfully placed orders for chat linking
      final List<Map<String, dynamic>> placedOrders = [];

      // Create an order for each seller
      for (var entry in sellerItems.entries) {
        final sellerId = entry.key;
        final sellerName = sellerNames[sellerId]!;
        final sellerPhone = sellerPhones[sellerId]!;
        final items = entry.value;

        debugPrint('📝 Creating order for seller: $sellerName');

        // Calculate subtotal for this seller's items
        double subtotal = 0;
        final orderItems = items.map((item) {
          double price;
          if (item['price'] is String) {
            price = double.parse(item['price']
                .toString()
                .replaceAll('₹', '')
                .replaceAll(',', ''));
          } else {
            price = (item['price'] as num).toDouble();
          }
          final quantity = item['quantity'] as int;
          subtotal += price * quantity;

          debugPrint(
              '  - Item: ${item['name']}, Price: $price, Qty: $quantity');

          return OrderItem(
            productId: item['productId'] ?? '',
            productName: item['name'],
            price: price,
            quantity: quantity,
            imageUrl: item['imageUrl'],
          );
        }).toList();

        debugPrint('💰 Subtotal for this seller: ₹$subtotal');

        // Calculate delivery fee based on subtotal
        double deliveryFee = 0.0;
        if (subtotal < 500) {
          deliveryFee = 50.0; // Only apply fee if subtotal < 500
        }

        debugPrint('🚚 Delivery fee for this seller: ₹$deliveryFee');

        // Generate order ID
        final orderId =
            FirebaseFirestore.instance.collection('orders').doc().id;
        debugPrint('🆔 Generated order ID: $orderId');

        // Create order
        final order = OrderModel(
          id: orderId,
          buyerId: authProvider.user!.uid,
          buyerName: _nameController.text,
          buyerEmail: authProvider.user!.email ?? '',
          buyerPhone: _phoneController.text,
          sellerId: sellerId,
          sellerName: sellerName,
          items: orderItems,
          subtotal: subtotal,
          deliveryFee: deliveryFee,
          total: subtotal + deliveryFee,
          deliveryAddress: _addressController.text,
          city: _cityController.text,
          postalCode: _postalCodeController.text.isNotEmpty
              ? _postalCodeController.text
              : null,
          paymentMethod: _selectedPaymentMethod!,
          orderStatus: _selectedPaymentMethod == 'Cash on Delivery'
              ? 'confirmed'
              : 'pending_contact',
          orderDate: DateTime.now(),
          expectedDeliveryDate: _selectedPaymentMethod == 'Cash on Delivery'
              ? DateTime.now().add(const Duration(days: 7))
              : null,
        );

        debugPrint('📤 Placing order...');
        final success = await orderProvider.placeOrder(order);

        if (!success) {
          debugPrint('❌ Failed to place order for seller: $sellerName');
          throw Exception('Order placement failed');
        }

        debugPrint('✅ Order placed successfully for seller: $sellerName');

        // Create chat and link order
        debugPrint('💬 Creating chat for order...');

        // Use the first item for chat details
        final firstItem = items.first;
        final productId = firstItem['productId'] ?? '';
        final productTitle = firstItem['name'] ?? 'Product';
        final productImage = firstItem['imageUrl'];

        // Check if chat already exists
        String? chatId = await chatProvider.getExistingChatId(
          buyerId: authProvider.user!.uid,
          sellerId: sellerId,
          productId: productId,
        );

        if (chatId == null) {
          // Create new chat
          debugPrint('🆕 Creating new chat for seller: $sellerName');

          // Generate a consistent chat ID
          final newChatId = _generateChatId(
            authProvider.user!.uid,
            sellerId,
            productId,
          );

          chatId = await chatProvider.getOrCreateChat(
            chatId: newChatId,
            buyerId: authProvider.user!.uid,
            buyerName: _nameController.text,
            sellerId: sellerId,
            sellerName: sellerName,
            productId: productId,
            productTitle: productTitle,
            productImage: productImage,
          );
        } else {
          debugPrint('✅ Using existing chat: $chatId');
        }

        // Send order confirmation message
        // Create detailed order summary message
        String orderDetails = '';
        orderDetails += '🛍️ **NEW ORDER PLACED**\n\n';
        orderDetails += '━━━━━━━━━━━━━━━━\n';
        orderDetails += '**Order ID:** ${orderId.substring(0, 8)}...\n';
        orderDetails +=
            '**Date:** ${DateTime.now().day}/${DateTime.now().month}/${DateTime.now().year}\n';
        orderDetails += '━━━━━━━━━━━━━━━━\n\n';
        orderDetails += '**ITEMS ORDERED:**\n';

// List all items in this order
        for (var i = 0; i < items.length; i++) {
          final item = items[i];
          final itemPrice = double.parse(
              item['price'].toString().replaceAll('₹', '').replaceAll(',', ''));
          final quantity = item['quantity'] as int;
          final totalItemPrice = itemPrice * quantity;

          orderDetails += '${i + 1}. **${item['name']}**\n';
          orderDetails += '   • Quantity: $quantity\n';
          orderDetails += '   • Price: ₹${itemPrice.toStringAsFixed(0)} each\n';
          orderDetails +=
              '   • Subtotal: ₹${totalItemPrice.toStringAsFixed(0)}\n\n';
        }

        orderDetails += '**BUYER DETAILS:**\n';
        orderDetails += '• **Name:** ${_nameController.text}\n';
        orderDetails += '• **Phone:** ${_phoneController.text}\n';
        orderDetails += '• **Address:** ${_addressController.text}\n';
        orderDetails += '• **City:** ${_cityController.text}\n';
        if (_postalCodeController.text.isNotEmpty) {
          orderDetails += '• **Postal Code:** ${_postalCodeController.text}\n';
        }
        orderDetails += '\n';

        orderDetails += '**PAYMENT METHOD:** ${_selectedPaymentMethod}\n\n';

        if (_selectedPaymentMethod == 'Contact Seller') {
          orderDetails +=
              '⚠️ **ACTION REQUIRED:** Please contact the buyer to arrange payment and pickup/delivery.\n';
        } else {
          orderDetails += '💰 **Payment:** Cash on Delivery\n';
        }

        debugPrint('💬 Sending detailed order confirmation message');
        await chatProvider.sendMessage(
          chatId: chatId,
          senderId: authProvider.user!.uid,
          senderName: _nameController.text,
          content: orderDetails,
        );

        // Link order to chat
        await chatProvider.linkOrderToChat(chatId, orderId);

        debugPrint('✅ Chat linked successfully for order: $orderId');

        // Store order info for success dialog with all details
        placedOrders.add({
          'sellerId': sellerId,
          'sellerName': sellerName,
          'sellerPhone': sellerPhone,
          'orderId': orderId,
          'items': items,
          'chatId': chatId,
          'productId': productId,
          'productTitle': productTitle,
        });
      }

      debugPrint('🎉 All orders placed successfully');

      if (mounted) {
        cart.clearCart();
        debugPrint('🧹 Cart cleared');

        // Extract data for success dialog
        final sellerNamesList =
            placedOrders.map((order) => order['sellerName'] as String).toList();
        final sellerPhonesList = placedOrders
            .map((order) => order['sellerPhone'] as String)
            .toList();
        final sellerIdsList =
            placedOrders.map((order) => order['sellerId'] as String).toList();
        final chatIdsList =
            placedOrders.map((order) => order['chatId'] as String).toList();
        final orderIdsList =
            placedOrders.map((order) => order['orderId'] as String).toList();
        final productIdsList =
            placedOrders.map((order) => order['productId'] as String).toList();
        final productTitlesList = placedOrders
            .map((order) => order['productTitle'] as String)
            .toList();

        // Navigate away from checkout screen before showing success
        // First, pop the checkout screen
        Navigator.pop(context);

        // Then show success dialog on the previous screen
        _showOrderSuccessDialog(
          sellerNames: sellerNamesList,
          sellerPhones: sellerPhonesList,
          sellerIds: sellerIdsList,
          chatIds: chatIdsList,
          orderIds: orderIdsList,
          productIds: productIdsList,
          productTitles: productTitlesList,
          placedOrders: placedOrders,
        );
      }
    } catch (e) {
      debugPrint('❌ Error in order processing: $e');
      if (mounted) {
        _showError('Failed to place order: ${e.toString()}');
      }
    } finally {
      if (mounted) {
        debugPrint('🏁 Order processing finished');
        setState(() => _isLoading = false);
      }
    }
  }

  // Helper method to generate consistent chat ID
  String _generateChatId(String userId1, String userId2, String productId) {
    final ids = [userId1, userId2]..sort();
    return '${ids[0]}_${ids[1]}_$productId';
  }

  //  Success dialog that shows on the previous screen
  // Success dialog with proper navigation using a captured navigator
  void _showOrderSuccessDialog({
    required List<String> sellerNames,
    required List<String> sellerPhones,
    required List<String> sellerIds,
    required List<String> chatIds,
    required List<String> orderIds,
    required List<String> productIds,
    required List<String> productTitles,
    required List<Map<String, dynamic>> placedOrders,
  }) {
    debugPrint('📱 Showing success dialog');
    final isContactSeller = _selectedPaymentMethod == 'Contact Seller';

    // Capture the navigator before showing the dialog
    final navigator = Navigator.of(context);

    showDialog(
      context: context,
      barrierDismissible: false,
      builder: (dialogContext) => AlertDialog(
        title: Icon(isContactSeller ? Icons.info_outline : Icons.check_circle,
            color: isContactSeller ? Colors.orange : Colors.green, size: 60),
        content: SingleChildScrollView(
          child: Column(
            mainAxisSize: MainAxisSize.min,
            children: [
              Text(
                isContactSeller
                    ? 'Order Request Sent!'
                    : 'Order Placed Successfully!',
                style: const TextStyle(
                  fontSize: 18,
                  fontWeight: FontWeight.bold,
                ),
              ),
              const SizedBox(height: 10),
              if (isContactSeller) ...[
                const Text(
                  'Please contact the seller(s) to arrange payment and pickup:',
                  textAlign: TextAlign.center,
                ),
                const SizedBox(height: 15),
                ...List.generate(sellerNames.length, (index) {
                  return Container(
                    margin: const EdgeInsets.only(bottom: 10),
                    padding: const EdgeInsets.all(10),
                    decoration: BoxDecoration(
                      color: Colors.grey[100],
                      borderRadius: BorderRadius.circular(8),
                    ),
                    child: Column(
                      children: [
                        Text(
                          sellerNames[index],
                          style: const TextStyle(fontWeight: FontWeight.bold),
                        ),
                        const SizedBox(height: 4),
                        Text(
                          'Phone: ${sellerPhones[index]}',
                          style: const TextStyle(color: Colors.blue),
                        ),
                        const SizedBox(height: 8),
                        // Button to open specific chat with this seller
                        ElevatedButton.icon(
                          onPressed: () {
                            debugPrint(
                                '👆 Chat with Seller clicked for ${sellerNames[index]}');
                            // Close the dialog
                            Navigator.pop(dialogContext);

                            // Use the captured navigator to navigate
                            navigator.push(
                              MaterialPageRoute(
                                builder: (context) => UserChatScreen(
                                  chatId: chatIds[index],
                                  otherUserName: sellerNames[index],
                                  productTitle: productTitles[index],
                                  otherUserId: sellerIds[index],
                                  productId: productIds[index],
                                ),
                              ),
                            );
                          },
                          icon: const Icon(Icons.chat, size: 18),
                          label: const Text('Chat with Seller'),
                          style: ElevatedButton.styleFrom(
                            backgroundColor: Colors.green,
                            foregroundColor: Colors.white,
                            minimumSize: const Size(double.infinity, 36),
                          ),
                        ),
                        const SizedBox(height: 4),
                        Text(
                          'Order ID: ${orderIds[index]}',
                          style:
                              TextStyle(fontSize: 10, color: Colors.grey[600]),
                        ),
                      ],
                    ),
                  );
                }),
                const SizedBox(height: 10),
                const Text(
                  'The seller has been notified and will respond soon',
                  style: TextStyle(fontSize: 12, color: Colors.grey),
                  textAlign: TextAlign.center,
                ),
              ] else ...[
                const Text(
                  'Thank you for shopping sustainably with KindCart',
                  textAlign: TextAlign.center,
                ),
              ],
            ],
          ),
        ),
        actions: [
          TextButton(
            onPressed: () {
              debugPrint('👆 Continue Shopping clicked');
              Navigator.pop(dialogContext);
              // Use the captured navigator to go home
              navigator.popUntil((route) => route.isFirst);
            },
            child: const Text('Continue Shopping'),
          ),
          if (isContactSeller)
            TextButton(
              onPressed: () {
                debugPrint('👆 View All Chats clicked');
                Navigator.pop(dialogContext);
                // Use the captured navigator to go to chats
                navigator.push(
                  MaterialPageRoute(
                    builder: (context) => const ChatsListScreen(),
                  ),
                );
              },
              child: const Text('View All Chats'),
            ),
        ],
      ),
    );
  }
