  // Robust price parsing method with error handling
  double _parsePrice(String priceString) {
    try {
      // Removed all non-numeric characters except decimal point
      String cleaned = priceString.replaceAll(RegExp(r'[^\d.]'), '');

      // Handle empty string
      if (cleaned.isEmpty) {
        debugPrint('⚠️ Empty price string, returning 0');
        return 0.0;
      }

      // Handle multiple decimal points
      if (cleaned.contains('.')) {
        List<String> parts = cleaned.split('.');
        if (parts.length > 2) {
          cleaned = parts[0] + '.' + parts.sublist(1).join();
        }
      }

      return double.parse(cleaned);
    } catch (e) {
      debugPrint('❌ Error parsing price "$priceString": $e');
      return 0.0; // Return 0 as fallback
    }
  }

