  @override
  void initState() {
    super.initState();
    debugPrint('🔄 CheckoutScreen initState');
    // Pre-fill user data if available
    WidgetsBinding.instance.addPostFrameCallback((_) {
      _prefillUserData();
    });
  }

  void _prefillUserData() {
    debugPrint('🔄 Pre-filling user data');
    final authProvider =
        Provider.of<app_auth.AuthProvider>(context, listen: false);
    final user = authProvider.user;
    final userData = authProvider.userData;

    if (user != null) {
      _nameController.text = userData?['name'] ?? user.displayName ?? '';
      _phoneController.text = userData?['phone'] ?? '';
      debugPrint(
          '✅ User data pre-filled: ${_nameController.text}, ${_phoneController.text}');
    }
  }

  @override
  void dispose() {
    debugPrint('🔄 CheckoutScreen dispose');
    _nameController.dispose();
    _phoneController.dispose();
    _addressController.dispose();
    _cityController.dispose();
    _postalCodeController.dispose();
    super.dispose();
  }

