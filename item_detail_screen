  Widget _buildInfoChip({
    required IconData icon,
    required String label,
    required Color color,
    bool showIcon = true,
  }) {
    return Container(
      padding: const EdgeInsets.symmetric(horizontal: 10, vertical: 5),
      decoration: BoxDecoration(
        color: color.withAlpha(20),
        borderRadius: BorderRadius.circular(20),
      ),
      child: Row(
        mainAxisSize: MainAxisSize.min,
        children: [
          if (showIcon) Icon(icon, size: 13, color: color),
          if (showIcon) const SizedBox(width: 5),
          if (!showIcon)
            Container(
              width: 6,
              height: 6,
              decoration: BoxDecoration(shape: BoxShape.circle, color: color),
            ),
          if (!showIcon) const SizedBox(width: 5),
          Text(
            label,
            style: TextStyle(
              color: color,
              fontWeight: FontWeight.w600,
              fontSize: 12,
            ),
          ),
        ],
      ),
    );
  }

  IconData _getCategoryIcon(String category) {
    switch (category.toLowerCase()) {
      case 'clothing':
        return Icons.checkroom;
      case 'electronics':
        return Icons.phone_android;
      case 'furniture':
        return Icons.chair;
      case 'books':
        return Icons.menu_book;
      case 'toys':
        return Icons.toys;
      case 'sports':
        return Icons.sports_soccer;
      default:
        return Icons.category;
    }
  }

  Color _getConditionColor(String condition) {
    switch (condition) {
      case 'Brand New':
      case 'Like New':
        return Colors.green;
      case 'Excellent':
      case 'Very Good':
        return Colors.teal;
      case 'Good':
        return Colors.blue;
      case 'Fair':
        return Colors.orange;
      case 'For Parts/Not Working':
        return Colors.red;
      default:
        return Colors.grey;
    }
  }

  void _showLoginRequiredDialog() {
    showDialog(
      context: context,
      builder: (context) => AlertDialog(
        title: const Text('Login Required'),
        content: const Text('Please login to add items to your cart'),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(context),
            child: const Text('Cancel'),
          ),
          ElevatedButton(
            onPressed: () {
              Navigator.pop(context);
              Navigator.pushNamed(context, '/auth');
            },
            style: ElevatedButton.styleFrom(
              backgroundColor: Colors.green,
              foregroundColor: Colors.white,
            ),
            child: const Text('Login'),
          ),
        ],
      ),
    );
  }

  Future<void> _addToCart() async {
    if (!mounted) return;
    final authProvider =
        Provider.of<app_auth.AuthProvider>(context, listen: false);
    if (!authProvider.isAuthenticated) {
      _showLoginRequiredDialog();
      return;
    }
    setState(() => _isLoading = true);
    try {
      final cartProvider = Provider.of<CartProvider>(context, listen: false);
      cartProvider.addToCart(_currentItem, quantity: 1);
      if (!mounted) return;

      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: const Text('✨ Added to cart successfully'),
          backgroundColor: Colors.green,
          duration: const Duration(seconds: 2),
          action: SnackBarAction(
            label: 'VIEW CART',
            textColor: Colors.white,
            onPressed: () {
              Navigator.push(
                context,
                MaterialPageRoute(builder: (context) => const CartScreen()),
              );
            },
          ),
        ),
      );
    } catch (e) {
      if (!mounted) return;
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: Text('Error adding to cart: ${e.toString()}'),
          backgroundColor: Colors.red,
        ),
      );
    } finally {
      if (mounted) setState(() => _isLoading = false);
    }
  }

  Future<void> _toggleWishlist() async {
    if (!mounted) return;

    final authProvider =
        Provider.of<app_auth.AuthProvider>(context, listen: false);
    final userId = authProvider.user?.uid;

    if (userId == null) return;

    setState(() => _isLoading = true);

    try {
      final wishlistProvider =
          Provider.of<WishlistProvider>(context, listen: false);
      await wishlistProvider.toggleWishlist(userId, _currentItem);

      setState(() {
        _isInWishlist = !_isInWishlist;
      });

      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: Text(
              _isInWishlist ? 'Added to wishlist' : 'Removed from wishlist'),
          backgroundColor: _isInWishlist ? Colors.green : Colors.red,
          duration: const Duration(seconds: 1),
        ),
      );
    } catch (e) {
      debugPrint('❌ Error: $e');
    } finally {
      if (mounted) setState(() => _isLoading = false);
    }
  }

  Future<void> _contactSeller() async {
    if (!mounted) return;

    final authProvider =
        Provider.of<app_auth.AuthProvider>(context, listen: false);

    if (!authProvider.isAuthenticated) {
      _showLoginRequiredDialog();
      return;
    }

    final userId = authProvider.user!.uid;

    if (userId == _currentItem.sellerId) {
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(
          content: Text('You cannot message yourself'),
          backgroundColor: Colors.orange,
        ),
      );
      return;
    }

    final userName = authProvider.userData?['name'] ??
        authProvider.user?.displayName ??
        'Buyer';

    setState(() => _isLoading = true);

    try {
      final chatProvider = Provider.of<ChatProvider>(context, listen: false);

      String? existingChatId = await chatProvider.getExistingChatId(
        buyerId: userId,
        sellerId: _currentItem.sellerId,
        productId: _currentItem.id,
      );

      String chatId;

      if (existingChatId != null) {
        chatId = existingChatId;
      } else {
        final generatedId = chatProvider.generateChatId(
          userId,
          _currentItem.sellerId,
          _currentItem.id,
        );

        chatId = await chatProvider.getOrCreateChat(
          chatId: generatedId,
          buyerId: userId,
          buyerName: userName,
          sellerId: _currentItem.sellerId,
          sellerName: _currentItem.sellerName,
          productId: _currentItem.id,
          productTitle: _currentItem.title,
          productImage: _currentItem.imageUrls.isNotEmpty
              ? _currentItem.imageUrls.first
              : null,
        );
      }

      if (!mounted) return;

      Navigator.push(
        context,
        MaterialPageRoute(
          builder: (context) => UserChatScreen(
            chatId: chatId,
            otherUserName: _currentItem.sellerName,
            productTitle: _currentItem.title,
            otherUserId: _currentItem.sellerId,
            productId: _currentItem.id,
          ),
        ),
      );
    } catch (e) {
      debugPrint('❌ Error in _contactSeller: $e');
      if (!mounted) return;
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: Text('Error starting chat: ${e.toString()}'),
          backgroundColor: Colors.red,
        ),
      );
    } finally {
      if (mounted) setState(() => _isLoading = false);
    }
  }

  // Complete Report Dialog with Firestore integration
  void _showReportDialog() {
    final authProvider =
        Provider.of<app_auth.AuthProvider>(context, listen: false);

    // Reset form
    _selectedReportReason = '';
    _reportDescriptionController.clear();
    _isSubmittingReport = false;

    // Check if user is logged in
    if (!authProvider.isAuthenticated) {
      _showLoginRequiredDialog();
      return;
    }

    // Don't allow reporting your own item
    if (authProvider.user?.uid == _currentItem.sellerId) {
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(
          content: Text('You cannot report your own item'),
          backgroundColor: Colors.orange,
        ),
      );
      return;
    }

    showDialog(
      context: context,
      barrierDismissible: false,
      builder: (dialogContext) => StatefulBuilder(
        builder: (context, setDialogState) {
          return AlertDialog(
            title: Row(
              children: [
                Icon(Icons.flag, color: Colors.red.shade700),
                const SizedBox(width: 8),
                const Text('Report Item'),
              ],
            ),
            content: SingleChildScrollView(
              child: Column(
                mainAxisSize: MainAxisSize.min,
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  const Text(
                    'Why are you reporting this item?',
                    style: TextStyle(fontWeight: FontWeight.bold),
                  ),
                  const SizedBox(height: 12),
                  DropdownButtonFormField<String>(
                    value: _selectedReportReason.isEmpty
                        ? null
                        : _selectedReportReason,
                    decoration: InputDecoration(
                      border: OutlineInputBorder(
                        borderRadius: BorderRadius.circular(8),
                      ),
                      contentPadding: const EdgeInsets.symmetric(
                          horizontal: 12, vertical: 8),
                    ),
                    hint: const Text('Select a reason'),
                    items: _reportReasons.map((reason) {
                      return DropdownMenuItem(
                        value: reason,
                        child: Text(reason),
                      );
                    }).toList(),
                    onChanged: (value) {
                      setDialogState(() {
                        _selectedReportReason = value ?? '';
                      });
                    },
                  ),
                  const SizedBox(height: 16),
                  const Text(
                    'Additional details (optional)',
                    style: TextStyle(fontWeight: FontWeight.bold),
                  ),
                  const SizedBox(height: 8),
                  TextField(
                    controller: _reportDescriptionController,
                    maxLines: 3,
                    decoration: InputDecoration(
                      hintText: 'Please provide more information...',
                      border: OutlineInputBorder(
                        borderRadius: BorderRadius.circular(8),
                      ),
                    ),
                  ),
                  const SizedBox(height: 16),
                  Container(
                    padding: const EdgeInsets.all(8),
                    decoration: BoxDecoration(
                      color: Colors.orange.shade50,
                      borderRadius: BorderRadius.circular(8),
                      border: Border.all(color: Colors.orange.shade200),
                    ),
                    child: Row(
                      children: [
                        Icon(Icons.info_outline,
                            size: 16, color: Colors.orange.shade700),
                        const SizedBox(width: 8),
                        Expanded(
                          child: Text(
                            'False reports may result in account action',
                            style: TextStyle(
                                fontSize: 11, color: Colors.orange.shade700),
                          ),
                        ),
                      ],
                    ),
                  ),
                ],
              ),
            ),
            actions: [
              TextButton(
                onPressed: _isSubmittingReport
                    ? null
                    : () {
                        Navigator.pop(dialogContext);
                      },
                child: const Text('Cancel'),
              ),
              ElevatedButton(
                onPressed: _isSubmittingReport
                    ? null
                    : () async {
                        if (_selectedReportReason.isEmpty) {
                          ScaffoldMessenger.of(context).showSnackBar(
                            const SnackBar(
                              content: Text('Please select a reason'),
                              backgroundColor: Colors.orange,
                            ),
                          );
                          return;
                        }

                        setDialogState(() => _isSubmittingReport = true);
                        await _submitReport();
                        setDialogState(() => _isSubmittingReport = false);

                        if (mounted) {
                          Navigator.pop(dialogContext);
                        }
                      },
                style: ElevatedButton.styleFrom(
                  backgroundColor: Colors.red,
                  foregroundColor: Colors.white,
                ),
                child: _isSubmittingReport
                    ? const SizedBox(
                        height: 20,
                        width: 20,
                        child: CircularProgressIndicator(strokeWidth: 2),
                      )
                    : const Text('Submit Report'),
              ),
            ],
          );
        },
      ),
    );
  }

  // Submit report to Firestore
  Future<void> _submitReport() async {
    final authProvider =
        Provider.of<app_auth.AuthProvider>(context, listen: false);
    final userId = authProvider.user?.uid;
    final userName = authProvider.userData?['name'] ??
        authProvider.user?.displayName ??
        'Anonymous';
    final userEmail = authProvider.user?.email ?? 'No email';

    if (userId == null) return;

    setState(() => _isSubmittingReport = true);

    try {
      final reportData = {
        'productId': _currentItem.id,
        'productTitle': _currentItem.title,
        'productImage': _currentItem.imageUrls.isNotEmpty
            ? _currentItem.imageUrls.first
            : null,
        'sellerId': _currentItem.sellerId,
        'sellerName': _currentItem.sellerName,
        'reporterId': userId,
        'reporterName': userName,
        'reporterEmail': userEmail,
        'reason': _selectedReportReason,
        'description': _reportDescriptionController.text.trim(),
        'status': 'pending',
        'createdAt': FieldValue.serverTimestamp(),
      };

      await FirebaseFirestore.instance.collection('reports').add(reportData);

      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          const SnackBar(
            content: Text(
                'Thank you for reporting. Our team will review this item.'),
            backgroundColor: Colors.green,
            duration: Duration(seconds: 3),
          ),
        );
      }
    } catch (e) {
      debugPrint('❌ Error submitting report: $e');
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content: Text('Error submitting report: ${e.toString()}'),
            backgroundColor: Colors.red,
          ),
        );
      }
    } finally {
      if (mounted) {
        setState(() => _isSubmittingReport = false);
      }
    }
  }

