        color: Colors.white,
        borderRadius: BorderRadius.circular(12),
        boxShadow: [
          BoxShadow(
            color: const Color.fromRGBO(158, 158, 158, 0.1), // Grey with 0.1 opacity            blurRadius: 10,
            offset: const Offset(0, 4), // FIXED: Added proper offset
