  // STEP 3: PRICING & LOCATION
  Widget _buildPricingAndLocationStep() {
    return Column(
      crossAxisAlignment: CrossAxisAlignment.start,
      children: [
        // Price
        const Text(
          'Price *',
          style: TextStyle(fontWeight: FontWeight.bold),
        ),
        const SizedBox(height: 8),
        TextFormField(
          controller: _priceController,
          keyboardType: TextInputType.number,
          decoration: InputDecoration(
            prefixText: '₹ ',
            hintText: '0.00',
            border: OutlineInputBorder(
              borderRadius: BorderRadius.circular(10),
            ),
            filled: true,
            fillColor: Colors.grey[50],
          ),
          validator: (value) {
            if (value == null || value.isEmpty) {
              return 'Please enter price';
            }
            final price = double.tryParse(value);
            if (price == null) {
              return 'Please enter a valid number';
            }
            if (price <= 0) {
              return 'Price must be greater than 0';
            }
            if (price > 1000000) {
              return 'Price seems too high';
            }
            return null;
          },
        ),
        const SizedBox(height: 15),

        // Original Price 
        TextFormField(
          controller: _originalPriceController,
          keyboardType: TextInputType.number,
          decoration: InputDecoration(
            labelText: 'Original Price (Optional)',
            prefixText: '₹ ',
            hintText: 'Show discount',
            border: OutlineInputBorder(
              borderRadius: BorderRadius.circular(10),
            ),
            filled: true,
            fillColor: Colors.grey[50],
          ),
        ),
        const SizedBox(height: 15),

        // Negotiable
        SwitchListTile(
          title: const Text('Price is negotiable'),
          value: _isNegotiable,
          onChanged: (value) {
            setState(() {
              _isNegotiable = value;
            });
          },
          secondary: const Icon(Icons.attach_money),
        ),
        const SizedBox(height: 20),

        // Location
        const Text(
          'Pickup Location *',
          style: TextStyle(fontWeight: FontWeight.bold),
        ),
        const SizedBox(height: 8),
        TextFormField(
          controller: _locationController,
          decoration: InputDecoration(
            prefixIcon: const Icon(Icons.location_on),
            hintText: 'Enter your city/locality',
            border: OutlineInputBorder(
              borderRadius: BorderRadius.circular(10),
            ),
            filled: true,
            fillColor: Colors.grey[50],
          ),
          validator: (value) {
            if (value == null || value.isEmpty) {
              return 'Please enter location';
            }
            return null;
          },
        ),
        const SizedBox(height: 15),

        // Shipping
        SwitchListTile(
          title: const Text('I can ship this item'),
          subtitle: const Text('Buyer pays shipping'),
          value: _canShip,
          onChanged: (value) {
            setState(() {
              _canShip = value;
            });
          },
          secondary: const Icon(Icons.local_shipping),
        ),
      ],
    );
  }

