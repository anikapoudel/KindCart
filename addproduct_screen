        const SizedBox(height: 20),

        // Product Details Summary
        _buildReviewItem('Title', _titleController.text),
        _buildReviewItem('Category', _selectedCategory ?? 'Not selected'),
        _buildReviewItem('Condition', _selectedCondition ?? 'Not selected'),
        _buildReviewItem('Price', '₹ ${_priceController.text}'),
        if (_originalPriceController.text.isNotEmpty)
          _buildReviewItem('Original Price', '₹ ${_originalPriceController.text}'),
        if (_brandController.text.isNotEmpty)
          _buildReviewItem('Brand', _brandController.text),
        if (_sizeController.text.isNotEmpty)
          _buildReviewItem('Size', _sizeController.text),
