class AddProductScreen extends StatefulWidget {
  const AddProductScreen({super.key});

  @override
  State<AddProductScreen> createState() => _AddProductScreenState();
}

class _AddProductScreenState extends State<AddProductScreen> {
  final _formKey = GlobalKey<FormState>();

  // CONTROLLERS
  final _titleController = TextEditingController();
  final _descriptionController = TextEditingController();
  final _priceController = TextEditingController();
  final _brandController = TextEditingController();
  final _sizeController = TextEditingController();
  final _colorController = TextEditingController();
  final _materialController = TextEditingController();
  final _locationController = TextEditingController();

  // SELECTED VALUES
  String? _selectedCategory;
  String? _selectedCondition;
  String? _selectedGender;

  // LISTS
  final List<String> _categories = ProductModel.categoryOptions;
  final List<String> _conditions = ProductModel.conditionOptions;
  final List<String> _genders = ['Men', 'Women', 'Unisex', 'Kids'];
  final List<String> _sizes = ['XS', 'S', 'M', 'L', 'XL', 'XXL', '3XL'];

  // IMAGES
  final List<XFile> _selectedImages = [];
  final ImagePicker _imagePicker = ImagePicker();

  // STEPPER
  int _currentStep = 0;
  bool _isSubmitting = false;

  @override
  void dispose() {
    _titleController.dispose();
    _descriptionController.dispose();
    _priceController.dispose();
    _brandController.dispose();
    _sizeController.dispose();
    _colorController.dispose();
    _materialController.dispose();
    _locationController.dispose();
    super.dispose();
  }

  // IMAGE PICKER
  Future<void> _pickImages() async {
    try {
      final List<XFile>? images = await _imagePicker.pickMultiImage(
        maxWidth: 1024,
        maxHeight: 1024,
        imageQuality: 85,
      );

      if (images != null && mounted) {
        setState(() {
          _selectedImages.addAll(images);
        });
      }
    } catch (e) {
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(content: Text('Error picking images: $e')),
        );
      }
    }
  }

  void _removeImage(int index) {
    setState(() {
      _selectedImages.removeAt(index);
    });
  }

  Widget _buildImagePreview(XFile image) {
    if (kIsWeb) {
      return Image.network(
        image.path,
        fit: BoxFit.cover,
        errorBuilder: (context, error, stackTrace) {
          return Container(
            color: Colors.grey[200],
            child: const Center(
              child: Icon(Icons.broken_image, color: Colors.grey),
            ),
          );
        },
        loadingBuilder: (context, child, loadingProgress) {
          if (loadingProgress == null) return child;
          return Center(
            child: CircularProgressIndicator(
              value: loadingProgress.expectedTotalBytes != null
                  ? loadingProgress.cumulativeBytesLoaded /
                      loadingProgress.expectedTotalBytes!
                  : null,
              strokeWidth: 2,
            ),
          );
        },
      );
    } else {
      return Image.file(
        File(image.path),
        fit: BoxFit.cover,
        errorBuilder: (context, error, stackTrace) {
          return Container(
            color: Colors.grey[200],
            child: const Center(
              child: Icon(Icons.broken_image, color: Colors.grey),
            ),
          );
        },
      );
    }
  }

  // SUBMIT FORM
  Future<void> _submitForm() async {
    debugPrint('🔵 SUBMIT FORM STARTED');
    if (_selectedCategory == null || _selectedCategory!.isEmpty) {
      debugPrint('❌ Category is null or empty');
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(
          content: Text('Please select a category'),
          backgroundColor: Colors.orange,
          duration: Duration(seconds: 2),
        ),
      );
      return;
    }
    debugPrint('✅ Category selected: $_selectedCategory');

    if (_selectedCondition == null || _selectedCondition!.isEmpty) {
      debugPrint('❌ Condition is null or empty');
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(
          content: Text('Please select a condition'),
          backgroundColor: Colors.orange,
          duration: Duration(seconds: 2),
        ),
      );
      return;
    }
    debugPrint('✅ Condition selected: $_selectedCondition');
    debugPrint('✅ Form validation passed');

    setState(() => _isSubmitting = true);

    try {
      final productProvider =
          Provider.of<ProductProvider>(context, listen: false);
      final authProvider = Provider.of<AuthProvider>(context, listen: false);

      if (!authProvider.isAuthenticated) {
        throw Exception('You must be logged in to list an item');
      }
      debugPrint('✅ User authenticated: ${authProvider.user?.uid}');

      if (authProvider.userRole != 'Seller') {
        throw Exception('Only sellers can list items');
      }
      debugPrint('✅ User role: ${authProvider.userRole}');

      if (!authProvider.isSellerApproved) {
        throw Exception('Your seller account is pending approval');
      }
      debugPrint('✅ Seller approved');

      Map<String, dynamic> specifications = {};

      if (_brandController.text.isNotEmpty) {
        specifications['brand'] = _brandController.text;
      }
      if (_sizeController.text.isNotEmpty) {
        specifications['size'] = _sizeController.text;
      }
      if (_colorController.text.isNotEmpty) {
        specifications['color'] = _colorController.text;
      }
      if (_materialController.text.isNotEmpty) {
        specifications['material'] = _materialController.text;
      }
      if (_selectedGender != null && _selectedGender!.isNotEmpty) {
        specifications['gender'] = _selectedGender;
      }

      if (_selectedImages.isEmpty) {
        throw Exception('Please add at least one photo');
      }
      debugPrint('✅ Images count: ${_selectedImages.length}');

      double price;
      try {
        price = double.parse(_priceController.text.trim());
        if (price <= 0) {
          throw Exception('Price must be greater than 0');
        }
      } catch (e) {
        throw Exception('Please enter a valid price');
      }
      debugPrint('✅ Price: $price');

      // Check location
      if (_locationController.text.trim().isEmpty) {
        throw Exception('Please enter a location');
      }
      debugPrint('✅ Location: ${_locationController.text.trim()}');

      final sellerName = authProvider.user?.displayName ??
          authProvider.user?.email?.split('@').first ??
          'Seller';

      // Store values in local variables to avoid null issues
      final String category = _selectedCategory!;
      final String condition = _selectedCondition!;
      final String title = _titleController.text.trim();
      final String description = _descriptionController.text.trim();
      final String location = _locationController.text.trim();

      debugPrint('📝 Submitting product:');
      debugPrint('   Title: $title');
      debugPrint('   Price: $price');
      debugPrint('   Category: $category');
      debugPrint('   Condition: $condition');
      debugPrint('   Location: $location');
      debugPrint('   Images: ${_selectedImages.length}');

      final success = await productProvider.addProduct(
        title: title,
        description: description,
        price: price,
        category: category,
        condition: condition,
        images: _selectedImages,
        specifications: specifications,
        location: location,
        sellerId: authProvider.user!.uid,
        sellerName: sellerName,
      );

      debugPrint('🔵 ProductProvider addProduct returned: $success');
      if (productProvider.errorMessage != null) {
        debugPrint('🔵 Error message: ${productProvider.errorMessage}');
      }

      if (!mounted) return;

      if (success) {
        debugPrint('✅ Product added successfully!');
        _showSuccessDialog();
      } else {
        debugPrint('❌ Failed to add product');
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content:
                Text(productProvider.errorMessage ?? 'Failed to list product'),
            backgroundColor: Colors.red,
            duration: const Duration(seconds: 3),
          ),
        );
      }
    } catch (e, stackTrace) {
      debugPrint('❌ Error submitting product: $e');
      debugPrint('❌ Stack trace: $stackTrace');

      if (!mounted) return;

      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: Text(e.toString()),
          backgroundColor: Colors.red,
          duration: const Duration(seconds: 5),
        ),
      );
    } finally {
      if (mounted) {
        setState(() => _isSubmitting = false);
      }
      debugPrint('🔵 SUBMIT FORM ENDED');
    }
  }

  void _showSuccessDialog() {
    showDialog(
      context: context,
      barrierDismissible: false,
      builder: (dialogContext) => AlertDialog(
        shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(20)),
        title: const Icon(Icons.check_circle, color: Colors.green, size: 60),
        content: Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            const Text(
              'Success!',
              style: TextStyle(
                fontSize: 24,
                fontWeight: FontWeight.bold,
              ),
            ),
            const SizedBox(height: 10),
            const Text(
              'Your item has been listed successfully.',
              textAlign: TextAlign.center,
            ),
            const SizedBox(height: 5),
            Text(
              'It will now be visible to buyers.',
              style: TextStyle(color: Colors.grey[600]),
            ),
          ],
        ),
        actions: [
          TextButton(
            onPressed: () {
              Navigator.pop(dialogContext);
              Navigator.pop(context);
            },
            child: const Text('OK'),
          ),
          ElevatedButton(
            onPressed: () {
              Navigator.pop(dialogContext);
              Navigator.pop(context);
              Navigator.pushNamed(context, '/shop');
            },
            style: ElevatedButton.styleFrom(
              backgroundColor: Colors.green,
              foregroundColor: Colors.white,
            ),
            child: const Text('View in Shop'),
          ),
        ],
      ),
    );
  }

  bool _validateCurrentStep() {
    switch (_currentStep) {
      case 0:
        // Validate basic info step
        if (_formKey.currentState == null) return false;
        final isValid = _formKey.currentState!.validate();
        if (!isValid) {
          return false;
        }
        if (_selectedCategory == null) {
          ScaffoldMessenger.of(context).showSnackBar(
            const SnackBar(
              content: Text('Please select a category'),
              backgroundColor: Colors.orange,
            ),
          );
          return false;
        }
        if (_selectedCondition == null) {
          ScaffoldMessenger.of(context).showSnackBar(
            const SnackBar(
              content: Text('Please select a condition'),
              backgroundColor: Colors.orange,
            ),
          );
          return false;
        }
        return true;
      case 1:
        if (_selectedImages.isEmpty) {
          ScaffoldMessenger.of(context).showSnackBar(
            const SnackBar(
              content: Text('Please add at least 1 photo'),
              backgroundColor: Colors.orange,
            ),
          );
          return false;
        }
        if (_priceController.text.isEmpty) {
          ScaffoldMessenger.of(context).showSnackBar(
            const SnackBar(
              content: Text('Please enter a price'),
              backgroundColor: Colors.orange,
            ),
          );
          return false;
        }
        final price = double.tryParse(_priceController.text);
        if (price == null || price <= 0) {
          ScaffoldMessenger.of(context).showSnackBar(
            const SnackBar(
              content: Text('Please enter a valid price'),
              backgroundColor: Colors.orange,
            ),
          );
          return false;
        }
        if (_locationController.text.isEmpty) {
          ScaffoldMessenger.of(context).showSnackBar(
            const SnackBar(
              content: Text('Please enter pickup location'),
              backgroundColor: Colors.orange,
            ),
          );
          return false;
        }
        return true;
      default:
        return true;
    }
  }

  @override
  Widget build(BuildContext context) {
    final authProvider = Provider.of<AuthProvider>(context);
    final screenWidth = MediaQuery.of(context).size.width;
    final isLargeScreen = screenWidth > 800;

    if (!authProvider.isAuthenticated) {
      return _buildAuthRequiredScreen(
          'Login Required', 'Please login to list items for sale', Icons.lock,
          () {
        Navigator.pop(context);
        Navigator.pushNamed(context, '/auth');
      }, 'Go to Login');
    }

    if (authProvider.userRole != 'Seller') {
      return _buildAuthRequiredScreen('Become a Seller',
          'You need a seller account to list items', Icons.store, () {
        Navigator.pop(context);
        Navigator.pushNamed(context, '/profile');
      }, 'Go to Profile');
    }

    if (!authProvider.isSellerApproved) {
      return Scaffold(
        appBar: AppBar(
          title: const Text('Approval Required'),
          leading: IconButton(
            icon: const Icon(Icons.arrow_back),
            onPressed: () => Navigator.pop(context),
          ),
        ),
        body: Center(
          child: Padding(
            padding: const EdgeInsets.all(20),
            child: Column(
              mainAxisAlignment: MainAxisAlignment.center,
              children: [
                Icon(Icons.hourglass_empty, size: 80, color: Colors.orange),
                const SizedBox(height: 20),
                const Text(
                  'Seller Approval Pending',
                  style: TextStyle(fontSize: 24, fontWeight: FontWeight.bold),
                ),
                const SizedBox(height: 10),
                const Text(
                  'Your seller account is being reviewed by admin.\nYou will be able to list items once approved.',
                  textAlign: TextAlign.center,
                ),
                const SizedBox(height: 20),
                Container(
                  padding: const EdgeInsets.all(15),
                  decoration: BoxDecoration(
                    color: Colors.orange.withAlpha(20),
                    borderRadius: BorderRadius.circular(10),
                  ),
                  child: const Text(
                    'This usually takes 1-2 business days',
                    style: TextStyle(color: Colors.orange),
                  ),
                ),
                const SizedBox(height: 30),
                ElevatedButton(
                  onPressed: () => Navigator.pop(context),
                  child: const Text('Go Back'),
                ),
              ],
            ),
          ),
        ),
      );
    }

    // Add Product Form
    return Scaffold(
      appBar: AppBar(
        elevation: 0,
        backgroundColor: Colors.transparent,
        foregroundColor: Colors.black87,
        title: const Text(
          'Sell an Item',
          style: TextStyle(
            fontWeight: FontWeight.bold,
            fontSize: 24,
          ),
        ),
        leading: IconButton(
          icon: const Icon(Icons.arrow_back_ios),
          onPressed: _showExitConfirmation,
        ),
        actions: [
          if (_currentStep == 2)
            Padding(
              padding: const EdgeInsets.only(right: 16),
              child: ElevatedButton(
                onPressed: _isSubmitting ? null : _submitForm,
                style: ElevatedButton.styleFrom(
                  backgroundColor: Colors.green,
                  foregroundColor: Colors.white,
                  shape: RoundedRectangleBorder(
                    borderRadius: BorderRadius.circular(30),
                  ),
                  padding:
                      const EdgeInsets.symmetric(horizontal: 24, vertical: 12),
                ),
                child: _isSubmitting
                    ? const SizedBox(
                        height: 20,
                        width: 20,
                        child: CircularProgressIndicator(
                          strokeWidth: 2,
                          valueColor:
                              AlwaysStoppedAnimation<Color>(Colors.white),
                        ),
                      )
                    : const Text(
                        'POST LISTING',
                        style: TextStyle(
                          fontWeight: FontWeight.bold,
                          fontSize: 14,
                        ),
                      ),
              ),
            ),
        ],
      ),
      body: isLargeScreen ? _buildWebLayout() : _buildMobileLayout(),
    );
  }

  Widget _buildWebLayout() {
    return Row(
      children: [
        Container(
          width: 300,
          decoration: BoxDecoration(
            color: Colors.grey[50],
            border: Border(
              right: BorderSide(color: Colors.grey[200]!),
            ),
          ),
          child: Column(
            children: [
              const SizedBox(height: 40),
              _buildStepIndicator(
                  0, 'Basic Information', 'Product title, category, condition'),
              _buildStepIndicator(
                  1, 'Media & Pricing', 'Photos, price, location'),
              _buildStepIndicator(
                  2, 'Review & Submit', 'Final review before posting'),
            ],
          ),
        ),
        Expanded(
          child: SingleChildScrollView(
            padding: const EdgeInsets.all(40),
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                _getCurrentStepContent(),
                const SizedBox(height: 40),
                _buildWebNavigationButtons(),
              ],
            ),
          ),
        ),
      ],
    );
  }

  Widget _buildStepIndicator(int step, String title, String subtitle) {
    final isActive = _currentStep == step;
    final isCompleted = _currentStep > step;

    return Padding(
      padding: const EdgeInsets.symmetric(horizontal: 24, vertical: 16),
      child: Row(
        children: [
          Container(
            width: 40,
            height: 40,
            decoration: BoxDecoration(
              shape: BoxShape.circle,
              color: isActive || isCompleted ? Colors.green : Colors.grey[300],
              border: Border.all(
                color: isActive ? Colors.green : Colors.transparent,
                width: 2,
              ),
            ),
            child: Center(
              child: isCompleted
                  ? const Icon(Icons.check, color: Colors.white, size: 20)
                  : Text(
                      '${step + 1}',
                      style: TextStyle(
                        color: isActive ? Colors.white : Colors.grey[600],
                        fontWeight: FontWeight.bold,
                      ),
                    ),
            ),
          ),
          const SizedBox(width: 16),
          Expanded(
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Text(
                  title,
                  style: TextStyle(
                    fontWeight: FontWeight.bold,
                    color: isActive ? Colors.green : Colors.black87,
                    fontSize: 16,
                  ),
                ),
                const SizedBox(height: 4),
                Text(
                  subtitle,
                  style: TextStyle(
                    color: Colors.grey[600],
                    fontSize: 12,
                  ),
                ),
              ],
            ),
          ),
        ],
      ),
    );
  }

  Widget _buildMobileLayout() {
    return Column(
      children: [
        Container(
          padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 12),
          child: Row(
            children: List.generate(3, (index) {
              final isActive = _currentStep == index;
              final isCompleted = _currentStep > index;
              return Expanded(
                child: Container(
                  height: 4,
                  margin: const EdgeInsets.symmetric(horizontal: 4),
                  decoration: BoxDecoration(
                    color: isActive || isCompleted
                        ? Colors.green
                        : Colors.grey[300],
                    borderRadius: BorderRadius.circular(2),
                  ),
                ),
              );
            }),
          ),
        ),
        Padding(
          padding: const EdgeInsets.symmetric(horizontal: 16),
          child: Row(
            mainAxisAlignment: MainAxisAlignment.spaceBetween,
            children: [
              _buildMobileStepLabel(0, 'Basic'),
              _buildMobileStepLabel(1, 'Media'),
              _buildMobileStepLabel(2, 'Review'),
            ],
          ),
        ),
        const SizedBox(height: 8),
        Expanded(
          child: SingleChildScrollView(
            padding: const EdgeInsets.all(20),
            child: Column(
              children: [
                _getCurrentStepContent(),
                const SizedBox(height: 30),
                _buildMobileNavigationButtons(),
              ],
            ),
          ),
        ),
      ],
    );
  }

  Widget _buildMobileStepLabel(int step, String label) {
    final isActive = _currentStep == step;
    return Text(
      label,
      style: TextStyle(
        color: isActive ? Colors.green : Colors.grey,
        fontWeight: isActive ? FontWeight.bold : FontWeight.normal,
        fontSize: 14,
      ),
    );
  }

  Widget _getCurrentStepContent() {
    switch (_currentStep) {
      case 0:
        return _buildBasicInfoStep();
      case 1:
        return _buildPhotosPriceLocationStep();
      case 2:
        return _buildReviewStep();
      default:
        return Container();
    }
  }

  Widget _buildBasicInfoStep() {
    return Form(
      key: _formKey,
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          const SizedBox(height: 13),
          const Text(
            'Product Details',
            style: TextStyle(
              fontSize: 24,
              fontWeight: FontWeight.bold,
            ),
          ),
          const SizedBox(height: 8),
          Text(
            'Tell buyers what you\'re selling',
            style: TextStyle(
              color: Colors.grey[600],
              fontSize: 14,
            ),
          ),
          const SizedBox(height: 24),
          _buildInputField(
            label: 'Product Title *',
            hint: 'e.g., Vintage Denim Jacket, Nike Air Max',
            icon: Icons.title,
            controller: _titleController,
            validator: (value) {
              if (value == null || value.isEmpty) return 'Please enter a title';
              if (value.length < 10)
                return 'Title must be at least 10 characters';
              return null;
            },
          ),
          const SizedBox(height: 20),
