import 'package:flutter/material.dart';

class DonateScreen extends StatelessWidget {
  const DonateScreen({super.key});

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: const Text('Donate Items'),
        leading: IconButton(
          icon: const Icon(Icons.arrow_back),
          onPressed: () => Navigator.pop(context),
        ),
      ),
      body: ListView(
        padding: const EdgeInsets.all(20),
        children: [
          // Header
          const Text(
            'What would you like to donate?',
            style: TextStyle(fontSize: 24, fontWeight: FontWeight.bold),
          ),
          const SizedBox(height: 10),
          const Text(
            'Your donations help reduce waste and support those in need',
            style: TextStyle(color: Colors.grey),
          ),
          const SizedBox(height: 30),

          // Donation Categories
          GridView.count(
            shrinkWrap: true,
            physics: const NeverScrollableScrollPhysics(),
            crossAxisCount: 2,
            childAspectRatio: 1.2,
            mainAxisSpacing: 15,
            crossAxisSpacing: 15,
            children: [
              _buildCategoryCard(
                icon: Icons.checkroom,
                title: 'Clothing',
                color: Colors.blue,
              ),
              _buildCategoryCard(
                icon: Icons.menu_book,
                title: 'Books',
                color: Colors.green,
              ),
              _buildCategoryCard(
                icon: Icons.toys,
                title: 'Toys',
                color: Colors.orange,
              ),
              _buildCategoryCard(
                icon: Icons.kitchen,
                title: 'Kitchenware',
                color: Colors.purple,
              ),
              _buildCategoryCard(
                icon: Icons.electrical_services,
                title: 'Electronics',
                color: Colors.red,
              ),
              _buildCategoryCard(
                icon: Icons.add,
                title: 'Other Items',
                color: Colors.grey,
              ),
            ],
          ),

          const SizedBox(height: 30),

          // Quick Donate Button
          ElevatedButton.icon(
            onPressed: () {},
            icon: const Icon(Icons.add_circle),
            label: const Text('Start New Donation'),
            style: ElevatedButton.styleFrom(
              padding: const EdgeInsets.symmetric(vertical: 16),
            ),
          ),

          const SizedBox(height: 20),

          // Donation Guidelines
          Card(
            child: Padding(
              padding: const EdgeInsets.all(15),
              child: Column(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  const Text(
                    'Donation Guidelines',
                    style: TextStyle(
                      fontSize: 18,
                      fontWeight: FontWeight.bold,
                    ),
                  ),
                  const SizedBox(height: 10),
                  const Text('• Items should be in good condition'),
                  const Text('• Clean and sanitize items before donating'),
                  const Text('• Include all parts and accessories'),
                  const Text('• No broken or hazardous items'),
                  const SizedBox(height: 15),
                  ElevatedButton(
                    onPressed: () {},
                    child: const Text('View Full Guidelines'),
                  ),
                ],
              ),
            ),
          ),
        ],
      ),
    );
  }

  Widget _buildCategoryCard({
    required IconData icon,
    required String title,
    required Color color,
  }) {
    return Card(
      child: InkWell(
        onTap: () {},
        borderRadius: BorderRadius.circular(10),
        child: Column(
          mainAxisAlignment: MainAxisAlignment.center,
          children: [
            Icon(icon, size: 40, color: color),
            const SizedBox(height: 10),
            Text(
              title,
              style: TextStyle(
                fontWeight: FontWeight.w600,
                color: color,
              ),
            ),
          ],
        ),
      ),
    );
  }
}
