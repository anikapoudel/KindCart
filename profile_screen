    final themeProvider = Provider.of<ThemeProvider>(context);
    final isDark = themeProvider.isDarkMode;
    final userRole = authProvider.userRole;

    // background color based on user role
    Color getBackgroundColor() {
      if (userRole == 'Seller') {
        return const Color(0xFFFFF7ED); // Light orange for seller
      } else if (userRole == 'Donor' || userRole == 'Buyer') {
        return Colors.white; // White/default for donor and buyer
      }
      return Colors.white; // Default for other roles
    }

    return Scaffold(
      backgroundColor: getBackgroundColor(),
      appBar: AppBar(
        title: Text(_getTitle(authProvider.userRole)),
        backgroundColor: _getRoleColor(authProvider.userRole),
        foregroundColor: Colors.white,
        leading: IconButton(
          icon: const Icon(Icons.arrow_back),
          onPressed: () => Navigator.pop(context),
        ),
        actions: [
          IconButton(
            icon: Icon(
                themeProvider.isDarkMode ? Icons.light_mode : Icons.dark_mode),
            onPressed: () => themeProvider.toggleTheme(),
          ),
          if (authProvider.userRole == 'Seller' &&
              authProvider.isSellerApproved)
            IconButton(
              icon: const Icon(Icons.add),
              onPressed: () {
                Navigator.push(
                  context,
                  MaterialPageRoute(
                      builder: (context) => const AddProductScreen()),
                );
              },
              tooltip: 'Add Product',
            ),
          if (authProvider.userRole == 'Donor')
            IconButton(
              icon: const Icon(Icons.add),
              onPressed: () {
                Navigator.pushNamed(context, '/add-donation');
              },
              tooltip: 'Add Donation',
            ),
        ],
      ),
      body: authProvider.isAuthenticated
          ? RefreshIndicator(
              onRefresh: () async {
                await authProvider.refreshUser();
                await _loadRoleSpecificData();
                await _loadAnnouncements();
                await _loadWishlistAndCart();
                await _checkPendingReports();
              },
              child: SingleChildScrollView(
                padding: const EdgeInsets.all(16),
                child: Column(
                  children: [
                    _buildProfileHeader(authProvider),
                    const SizedBox(height: 24),
                    if (authProvider.userRole == 'Buyer') _buildBuyerContent(),
                    if (authProvider.userRole == 'Seller')
                      _buildSellerContent(authProvider),
                    if (authProvider.userRole == 'Donor') _buildDonorContent(),
                    if (authProvider.userRole == 'Admin') _buildAdminContent(),
                    const SizedBox(height: 24),
                    _buildCommonSettings(),
                    const SizedBox(height: 16),
                    _buildLogoutButton(authProvider),
                    const SizedBox(height: 20),
                  ],
                ),
              ),
            )
          : _buildLoginPrompt(),
      bottomNavigationBar: _buildBottomNavigationBar(userRole, isDark),
    );
  }

  String _getTitle(String? role) {
    switch (role) {
      case 'Buyer':
        return 'My Account';
      case 'Seller':
        return 'My Account';
      case 'Donor':
        return 'Donor Impact';
      case 'Admin':
        return 'Admin Panel';
      default:
        return 'Profile';
    }
  }

  Color _getRoleColor(String? role) {
    switch (role) {
      case 'Buyer':
        return Colors.pinkAccent;
      case 'Seller':
        return Colors.orange;
      case 'Donor':
        return Colors.purple;
      case 'Admin':
        return Colors.deepPurple;
      default:
        return Colors.green;
    }
  }

