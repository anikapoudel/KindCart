import 'package:flutter/material.dart';
import 'package:provider/provider.dart';
import '../providers/auth_provider.dart';
import '../providers/product_provider.dart';
import '../theme_provider.dart';
import 'auth_screen.dart';
import '../admin/approval_screen.dart';
import 'addproduct_screen.dart';
import 'adddonation_screen.dart';
import 'wishlist_screen.dart';

class ProfileScreen extends StatefulWidget {
  const ProfileScreen({super.key});

  @override
  State<ProfileScreen> createState() => _ProfileScreenState();
}

class _ProfileScreenState extends State<ProfileScreen> {
  Map<String, dynamic>? _userData;

  @override
  void initState() {
    super.initState();
    WidgetsBinding.instance.addPostFrameCallback((_) {
      _loadUserData();
      _loadRoleSpecificData();
    });
  }

  Future<void> _loadUserData() async {
    final authProvider = Provider.of<AuthProvider>(context, listen: false);
    if (authProvider.isAuthenticated) {
      final data = await authProvider.getUserData();
      if (mounted) setState(() => _userData = data);
    }
  }

  Future<void> _loadRoleSpecificData() async {
    final authProvider = Provider.of<AuthProvider>(context, listen: false);
    final productProvider = Provider.of<ProductProvider>(context, listen: false);

    if (authProvider.isAuthenticated && authProvider.userRole == 'Seller') {
      await productProvider.loadUserProducts(authProvider.user!.uid);
    }
  }

  @override
  Widget build(BuildContext context) {
    final authProvider = Provider.of<AuthProvider>(context);
    final themeProvider = Provider.of<ThemeProvider>(context);

    return Scaffold(
      appBar: AppBar(
        title: Text(_getTitle(authProvider.userRole)),
        backgroundColor: _getRoleColor(authProvider.userRole),
        foregroundColor: Colors.white,
        actions: [
          IconButton(
            icon: Icon(themeProvider.isDarkMode ? Icons.light_mode : Icons.dark_mode),
            onPressed: () => themeProvider.toggleTheme(),
          ),
          // Role-specific action buttons
          if (authProvider.userRole == 'Seller')
            IconButton(
              icon: const Icon(Icons.add),
              onPressed: () {
                Navigator.push(
                  context,
                  MaterialPageRoute(builder: (context) => const AddProductScreen()),
                );
              },
            ),
          if (authProvider.userRole == 'Donor')
            IconButton(
              icon: const Icon(Icons.add),
              onPressed: () {
                Navigator.pushNamed(context, '/add-donation');
              },
            ),
        ],
      ),
      body: authProvider.isAuthenticated
          ? RefreshIndicator(
        onRefresh: () async {
          await _loadUserData();
          await _loadRoleSpecificData();
        },
        child: SingleChildScrollView(
          padding: const EdgeInsets.all(16),
          child: Column(
            children: [
              //  SECTION 1: PROFILE HEADER (Common for all)
              _buildProfileHeader(authProvider),

              const SizedBox(height: 24),

              //  SECTION 2: ROLE-SPECIFIC CONTENT
              if (authProvider.userRole == 'Buyer') _buildBuyerContent(),
              if (authProvider.userRole == 'Seller') _buildSellerContent(authProvider),
              if (authProvider.userRole == 'Donor') _buildDonorContent(),
              if (authProvider.userRole == 'Admin') _buildAdminContent(),

              const SizedBox(height: 24),

              //  SECTION 3: COMMON SETTINGS (All users)
              _buildCommonSettings(),

              const SizedBox(height: 16),

              //  SECTION 4: LOGOUT
              _buildLogoutButton(authProvider),

              const SizedBox(height: 20),
            ],
          ),
        ),
      )
          : _buildLoginPrompt(),
    );
  }

  //  HELPER METHODS

  String _getTitle(String? role) {
    switch (role) {
      case 'Buyer': return 'My Account';
      case 'Seller': return 'Seller Dashboard';
      case 'Donor': return 'Donor Impact';
      case 'Admin': return 'Admin Panel';
      default: return 'Profile';
    }
  }

  Color _getRoleColor(String? role) {
    switch (role) {
      case 'Buyer': return Colors.blue;
      case 'Seller': return Colors.orange;
      case 'Donor': return Colors.purple;
      case 'Admin': return Colors.deepPurple;
      default: return Colors.green;
    }
  }

  //  SECTION 1: PROFILE HEADER

  Widget _buildProfileHeader(AuthProvider auth) {
    final user = auth.user;
    final userName = _userData?['name'] ?? user?.displayName ?? user?.email?.split('@')[0] ?? 'User';
    final userEmail = user?.email ?? 'No email';
    final userPhone = _userData?['phone'] ?? '';
    final isVerified = auth.isEmailVerified;

    return Card(
      elevation: 2,
      shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(16)),
      child: Padding(
        padding: const EdgeInsets.all(20),
        child: Row(
          children: [
            // Avatar with verification badge
            Stack(
              children: [
                CircleAvatar(
                  radius: 40,
                  backgroundColor: _getRoleColor(auth.userRole).withAlpha(30),
                  backgroundImage: user?.photoURL != null ? NetworkImage(user!.photoURL!) : null,
                  child: user?.photoURL == null
                      ? Text(
                    userName.isNotEmpty ? userName[0].toUpperCase() : 'U',
                    style: TextStyle(
                      fontSize: 32,
                      fontWeight: FontWeight.bold,
                      color: _getRoleColor(auth.userRole),
                    ),
                  )
                      : null,
                ),
                if (isVerified)
                  Positioned(
                    bottom: 0,
                    right: 0,
                    child: Container(
                      padding: const EdgeInsets.all(4),
                      decoration: const BoxDecoration(
                        color: Colors.green,
                        shape: BoxShape.circle,
                      ),
                      child: const Icon(Icons.check, color: Colors.white, size: 16),
                    ),
                  ),
              ],
            ),
            const SizedBox(width: 16),

            // User info
            Expanded(
              child: Column(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  Row(
                    children: [
                      Expanded(
                        child: Text(
                          userName,
                          style: const TextStyle(fontSize: 20, fontWeight: FontWeight.bold),
                          maxLines: 1,
                          overflow: TextOverflow.ellipsis,
                        ),
                      ),
                      IconButton(
                        icon: const Icon(Icons.edit, size: 20),
                        onPressed: () => _showEditProfileDialog(auth),
                        padding: EdgeInsets.zero,
                        constraints: const BoxConstraints(),
                      ),
                    ],
                  ),
                  const SizedBox(height: 4),
                  Text(userEmail, style: TextStyle(color: Colors.grey[600], fontSize: 14)),
                  if (userPhone.isNotEmpty) ...[
                    const SizedBox(height: 2),
                    Text(userPhone, style: TextStyle(color: Colors.grey[600], fontSize: 12)),
                  ],
                  const SizedBox(height: 8),
                  Container(
                    padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 4),
                    decoration: BoxDecoration(
                      color: _getRoleColor(auth.userRole).withAlpha(20),
                      borderRadius: BorderRadius.circular(20),
                    ),
                    child: Text(
                      auth.userRole ?? 'Member',
                      style: TextStyle(
                        color: _getRoleColor(auth.userRole),
                        fontWeight: FontWeight.w500,
                        fontSize: 12,
                      ),
                    ),
                  ),
                ],
              ),
            ),
          ],
        ),
      ),
    );
  }

  //  SECTION 2: ROLE-SPECIFIC CONTENT

  // ----- BUYER CONTENT -----
  Widget _buildBuyerContent() {
    return Column(
      crossAxisAlignment: CrossAxisAlignment.start,
      children: [
        const Text('Shopping', style: TextStyle(fontSize: 18, fontWeight: FontWeight.bold)),
        const SizedBox(height: 12),
        Card(
          child: Column(
            children: [
              _buildMenuItem(
                icon: Icons.shopping_bag,
                title: 'My Orders',
                subtitle: 'Track your purchases',
                onTap: () => _showComingSoon(),
              ),
              _buildMenuItem(
                icon: Icons.favorite,
                title: 'Wishlist',
                subtitle: 'Items you saved',
                onTap: () {
                  Navigator.push(
                    context,
                    MaterialPageRoute(builder: (context) => const WishlistScreen()),
                  );
                },
              ),
              _buildMenuItem(
                icon: Icons.location_on,
                title: 'Saved Addresses',
                subtitle: 'Manage delivery locations',
                onTap: () => _showComingSoon(),
              ),
              _buildMenuItem(
                icon: Icons.payment,
                title: 'Payment Methods',
                subtitle: 'Add or remove payment options',
